# ----------------------------------------------------------------------------
# Eagle Eye — required environment variables
# Copy to .env.local and fill in. Never commit real secrets.
# ----------------------------------------------------------------------------

# App ------------------------------------------------------------------------
# Canonical URL (no trailing slash). Used by server actions and cron callers.
NEXT_PUBLIC_APP_URL=https://eagle-eye.hatedapps.pl
# Optional alias, some older code paths read this.
NEXT_PUBLIC_SITE_URL=https://eagle-eye.hatedapps.pl

# Supabase (self-hosted) ------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://supabase.hatedapps.pl
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# service_role key — server only, bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Admin access ---------------------------------------------------------------
# Email of the single user granted /dashboard/admin access.
ADMIN_EMAIL=you@example.com

# Scraper + cron authentication ----------------------------------------------
# Bearer token required by /api/scraper/* and /api/notifications/send-daily.
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-random-hex

# AI (Anthropic) -------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Email (Resend) -------------------------------------------------------------
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Eagle Eye <hello@hatedapps.pl>

# Stripe ---------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_BASIC_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...
